<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beijixing.system.mapper.SysJobLogMapper">

    <resultMap id="BaseResultMap" type="com.beijixing.system.entity.SysJobLog">
        <id column="id" property="id"/>
        <result column="job_id" property="jobId"/>
        <result column="job_name" property="jobName"/>
        <result column="job_group" property="jobGroup"/>
        <result column="exec_status" property="execStatus"/>
        <result column="exec_duration" property="execDuration"/>
        <result column="exec_result" property="execResult"/>
        <result column="exception_info" property="exceptionInfo"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="create_time" property="createTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectRecentByJobId" resultMap="BaseResultMap">
        SELECT * FROM sys_job_log
        WHERE job_id = #{jobId} AND deleted = 0
        ORDER BY create_time DESC
        LIMIT #{limit}
    </select>

    <select id="selectFailedLogs" resultMap="BaseResultMap">
        SELECT * FROM sys_job_log
        WHERE exec_status = 0 AND deleted = 0
        ORDER BY create_time DESC
        LIMIT #{limit}
    </select>

</mapper>
