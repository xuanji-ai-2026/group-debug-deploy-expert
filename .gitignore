# ============================================
# ZERO-TH LAW: Project Absolute Isolation
# WHITE-LIST MODE: Only allow skill framework files
# ============================================

# ✅ ALLOW: Skill core files (explicitly whitelist)
!SKILL.md
!LICENSE
!skill.json
!package.json
!README-DEPLOY.md
!README.md
!USER_GUIDE.md
!USE_CASES.md
!COMPETITIVE_ADVANTAGE.md
!WEB_PUBLISH_GUIDE.md
!MULTI_PLATFORM_PUBLISH_GUIDE.md
!MARKETPLACE_SUBMISSION_GUIDE.md
!install.sh
!install.ps1
!VERSION
!checksums.sha256
!.gitignore

# ✅ Allow publish directory (marketplace packages)
!publish/
!publish/**

# ✅ Allow .trae directory (skill definitions)
!.trae/
!.trae/**

# ❌ BLOCK EVERYTHING ELSE (nuclear option)
/*
!/*/

# ❌ Block all project directories
/backend/
/frontend/
/mobile/
/deploy/
/tools/
/docs/
/scripts/
/nacos-config/

# ❌ Block all project files by pattern
*.py
*.java
*.xml
*.zip
*.pem

# ✅ Exception: Allow install scripts (after block rule)
!install.sh
!install.ps1

# ❌ Block all other .sh files
*.sh

# ✅ Exception: Allow specific .md files (after block rule)
!README.md
!USER_GUIDE.md
!USE_CASES.md
!COMPETITIVE_ADVANTAGE.md
!WEB_PUBLISH_GUIDE.md
!MULTI_PLATFORM_PUBLISH_GUIDE.md
!MARKETPLACE_SUBMISSION_GUIDE.md
!README-DEPLOY.md

# ❌ Block all other .md files
*.md

# ❌ Block binary and build artifacts
*.jar
*.war
*.class
*.exe
*.dll
*.so
*.dylib
