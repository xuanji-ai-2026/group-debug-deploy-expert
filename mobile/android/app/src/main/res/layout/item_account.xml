<?xml version="1.0" encoding="utf-8"?>
<!--
    北极星AI商机获客系统 - 账号列表项布局
    展示单个社媒账号的信息卡片
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 头部信息行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 平台图标 -->
            <ImageView
                android:id="@+id/ivPlatform"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="平台图标"
                tools:src="@drawable/ic_platform_douyin" />

            <!-- 平台名称 -->
            <TextView
                android:id="@+id/tvPlatformName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="抖音" />

            <!-- 默认标识 -->
            <com.google.android.material.chip.Chip
                android:id="@+id/tvDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="默认"
                android:textSize="11sp"
                android:textColor="@color/brand_primary"
                android:visibility="gone"
                app:chipBackgroundColor="@color/brand_primary_alpha_20"
                app:chipMinHeight="20dp"
                app:chipStrokeWidth="0dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- 状态标签 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_tag"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:textSize="11sp"
                tools:text="正常"
                tools:textColor="@color/success" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/bg_divider" />

        <!-- 账号信息行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 头像 -->
            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="账号头像"
                tools:src="@drawable/ic_account_circle" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- 账号名称 -->
                <TextView
                    android:id="@+id/tvAccountName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="北极星官方账号" />

                <!-- 数据统计 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvFanCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        tools:text="粉丝 1.2万" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:layout_marginHorizontal="8dp"
                        android:layout_gravity="center_vertical"
                        android:background="@color/bg_divider" />

                    <TextView
                        android:id="@+id/tvNoteCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        tools:text="作品 128" />

                </LinearLayout>

                <!-- 绑定时间 -->
                <TextView
                    android:id="@+id/tvBindTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/text_tertiary"
                    android:textSize="11sp"
                    tools:text="绑定于 2024-01-15" />

            </LinearLayout>

            <!-- 健康度卡片（可点击） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHealth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/bg_page"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/bg_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressHealth"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:progress="85"
                        app:indicatorColor="@color/success"
                        app:indicatorSize="40dp"
                        app:trackColor="@color/bg_divider"
                        app:trackThickness="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="健康度"
                        android:textColor="@color/text_tertiary"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/tvHealthScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/success"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="85" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/bg_divider" />

        <!-- 操作按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSetDefault"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="设为默认"
                android:textColor="@color/brand_primary"
                android:textSize="13sp"
                app:icon="@drawable/ic_star"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                app:iconTint="@color/brand_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReauth"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="重新授权"
                android:textColor="@color/warning"
                android:textSize="13sp"
                app:icon="@drawable/ic_refresh"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                app:iconTint="@color/warning" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUnbind"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="解绑"
                android:textColor="@color/error"
                android:textSize="13sp"
                app:icon="@drawable/ic_link_off"
                app:iconGravity="textStart"
                app:iconPadding="4dp"
                app:iconSize="16dp"
                app:iconTint="@color/error" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
