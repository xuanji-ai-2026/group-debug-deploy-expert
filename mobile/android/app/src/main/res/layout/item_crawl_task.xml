<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_task_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="任务名称"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_platform"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="抖音"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_platform_douyin" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="进行中"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_status_running" />

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_task"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="45"
            android:progressDrawable="@drawable/progress_horizontal" />

        <TextView
            android:id="@+id/tv_statistics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="500条评论 | 85高意向 | 23商机"
            android:textSize="13sp"
            android:textColor="#666666" />

        <TextView
            android:id="@+id/tv_create_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="创建时间: 2024-01-15 14:30"
            android:textSize="11sp"
            android:textColor="#999999" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="end">

            <TextView
                android:id="@+id/btn_pause"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="暂停"
                android:textSize="13sp"
                android:textColor="#FF9800"
                android:background="@drawable/bg_button_outline_orange"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_stop"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="停止"
                android:textSize="13sp"
                android:textColor="#F44336"
                android:background="@drawable/bg_button_outline_red"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_analyze"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="AI分析"
                android:textSize="13sp"
                android:textColor="#2196F3"
                android:background="@drawable/bg_button_outline_blue"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_generate_leads"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:text="生成商机"
                android:textSize="13sp"
                android:textColor="#4CAF50"
                android:background="@drawable/bg_button_outline_green"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
