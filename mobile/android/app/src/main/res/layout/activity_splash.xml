<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_gradient">

    <!-- 动态背景装饰 -->
    <View
        android:id="@+id/decorCircle1"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_decor_circle"
        android:alpha="0.25" />

    <View
        android:id="@+id/decorCircle2"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_alignParentStart="true"
        android:layout_marginTop="280dp"
        android:layout_marginStart="-50dp"
        android:background="@drawable/bg_decor_circle"
        android:alpha="0.18" />

    <View
        android:id="@+id/decorCircle3"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:layout_marginEnd="40dp"
        android:layout_alignParentEnd="true"
        android:background="@drawable/bg_decor_circle"
        android:alpha="0.15" />

    <!-- 主内容容器 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp">

        <!-- Logo区域 - 增强光晕效果 -->
        <RelativeLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginBottom="28dp">

            <ImageView
                android:id="@+id/ivLogoGlow"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:src="@drawable/ic_logo_white"
                android:alpha="0.3"
                android:scaleType="fitCenter"
                android:contentDescription="Logo Glow" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_centerInParent="true"
                android:src="@drawable/ic_logo_white"
                android:alpha="0"
                android:contentDescription="Logo" />

        </RelativeLayout>

        <!-- 主标题 - 增强视觉效果 -->
        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:gravity="center"
            android:shadowColor="#80000000"
            android:shadowDx="3"
            android:shadowDy="3"
            android:shadowRadius="6"
            android:layout_marginBottom="16dp"
            android:alpha="0" />

        <!-- 副标题标语 -->
        <TextView
            android:id="@+id/tvLine1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#E8F0FF"
            android:textSize="15sp"
            android:textStyle="italic"
            android:letterSpacing="0.12"
            android:gravity="center"
            android:shadowColor="#30000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="3"
            android:alpha="0"
            android:layout_marginBottom="28dp" />

        <!-- 核心功能卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="36dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#22FFFFFF"
            android:alpha="0"
            android:id="@+id/cardContent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvLine2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:lineSpacingExtra="8dp"
                    android:gravity="center"
                    android:alpha="0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvLine3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F0F4FF"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:lineSpacingExtra="7dp"
                    android:gravity="center"
                    android:alpha="0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvLine4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:lineSpacingExtra="8dp"
                    android:gravity="center"
                    android:alpha="0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvLine5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#F0F4FF"
                    android:textSize="13sp"
                    android:letterSpacing="0.06"
                    android:lineSpacingExtra="7dp"
                    android:gravity="center"
                    android:alpha="0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvLine6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:lineSpacingExtra="8dp"
                    android:gravity="center"
                    android:alpha="0"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/tvLine7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFE8F0"
                    android:textSize="14sp"
                    android:textStyle="bold|italic"
                    android:letterSpacing="0.1"
                    android:lineSpacingExtra="8dp"
                    android:gravity="center"
                    android:alpha="0" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 进入应用按钮 - 增强交互效果 -->
        <Button
            android:id="@+id/btnEnter"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✨ 立即体验 · 开启智能获客之旅"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            android:elevation="6dp"
            android:stateListAnimator="@null"
            android:alpha="0"
            android:layout_marginBottom="24dp"
            android:letterSpacing="0.05" />

        <!-- 版本号信息 - 增强显示 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:alpha="0"
            android:id="@+id/layoutVersion"
            android:paddingVertical="8dp"
            android:paddingHorizontal="16dp"
            android:background="@drawable/bg_version_tag">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 "
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#C8D0E8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  |  "
                android:textColor="#8090A8"
                android:textSize="11sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by AI"
                android:textColor="#9098B0"
                android:textSize="11sp"
                android:textStyle="italic" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
