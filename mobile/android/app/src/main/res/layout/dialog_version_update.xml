<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="24dp">

    <!-- 版本图标和标题 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎉"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvUpdateTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="发现新版本 v1.0.20"
            android:textColor="#1a1a2e"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- 版本信息卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F8F9FE"
        android:padding="16dp"
        android:layout_marginBottom="16dp">

        <!-- 当前版本 vs 新版本 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="当前版本："
                android:textColor="#666666"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCurrentVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.18"
                android:textColor="#999999"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="最新版本："
                android:textColor="#666666"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvNewVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0.20"
                android:textColor="#667eea"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E4EC"
            android:layout_marginVertical="10dp" />

        <!-- 更新大小和发布时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvUpdateSize"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📦 更新大小：28.0 MB"
                android:textColor="#888888"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvReleaseDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 2025-01-22"
                android:textColor="#888888"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 更新内容列表 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="20dp"
        android:background="#FFFFFF"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🔥 重大更新 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔥 重大更新"
                android:textColor="#FF5722"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvMajorUpdates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 全新UI设计，视觉体验全面升级\n• 核心架构重构，性能提升50%\n• 新增智能获客引擎V2.0"
                android:textColor="#444444"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="16dp" />

            <!-- ✅ 问题修复 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ 问题修复"
                android:textColor="#4CAF50"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFixes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 修复网络连接错误（API路径配置）\n• 修复启动页显示异常问题\n• 优化Tab切换交互体验\n• 解决部分机型兼容性问题"
                android:textColor="#666666"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="16dp" />

            <!-- 🚀 新增功能 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🚀 新增功能"
                android:textColor="#2196F3"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvFeatures"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 版本迭代提醒功能\n• 应用内自动更新升级\n• 完整合规文档体系\n• 增强网络诊断日志"
                android:textColor="#666666"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp"
                android:layout_marginBottom="16dp" />

            <!-- ⚡ 性能优化 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡ 性能优化"
                android:textColor="#9C27B0"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvOptimizations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 启动速度提升40%\n• 内存占用减少30%\n• 网络请求响应更快\n• 动画效果更加流畅"
                android:textColor="#666666"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp" />

        </LinearLayout>

    </ScrollView>

    <!-- 强制更新提示 -->
    <TextView
        android:id="@+id/tvForceUpdateHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ 此版本为重要安全更新，建议立即更新"
        android:textColor="#FF5722"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- 按钮区域 -->
    <Button
        android:id="@+id/btnConfirmUpdate"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="✨ 立即更新"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_primary"
        android:elevation="3dp"
        android:stateListAnimator="@null"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvSkipVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="暂时跳过，稍后再说"
        android:textColor="#999999"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingVertical="8dp" />

</LinearLayout>
