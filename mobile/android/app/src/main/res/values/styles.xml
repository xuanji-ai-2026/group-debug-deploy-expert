<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Login Page Specific Styles - 避免与themes.xml冲突 -->

    <!-- Login Input Field Styles -->
    <style name="LoginInputStyle.Default" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>

    <!-- Login Button Styles -->
    <style name="LoginButtonStyle.Primary" parent="Widget.Material3.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">4dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="rippleColor">#33FFFFFF</item>
    </style>

    <style name="LoginButtonStyle.Secondary" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="cornerRadius">20dp</item>
    </style>

    <!-- Login Text Styles -->
    <style name="LoginTextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="fontFamily">sans-serif-medium</item>
    </style>

    <style name="LoginTextAppearance.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:alpha">0.9</item>
    </style>

    <style name="LoginTextAppearance.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="LoginTextAppearance.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
    </style>

    <!-- Login Card Style -->
    <style name="LoginCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">8dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Login Tab Style -->
    <style name="LoginTabStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tab_text_color_selector</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_tab_selector</item>
        <item name="android:paddingVertical">8dp</item>
    </style>

    <!-- 紧凑型TAB（用于登录页优化） -->
    <style name="LoginTabStyle.Compact">
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/tab_text_color_selector</item>
        <item name="android:gravity">center</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">@drawable/bg_tab_selector</item>
        <item name="android:paddingVertical">6dp</item>
    </style>

    <!-- 紧凑型输入框（用于登录页优化） -->
    <style name="LoginInputStyle.Compact" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxBackgroundColor">@color/bg_input</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="hintTextColor">@color/text_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">15sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
    </style>

    <!-- 文本按钮（用于发送验证码） -->
    <style name="LoginButtonStyle.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <!-- 小号正文（用于忘记密码等） -->
    <style name="LoginTextAppearance.Body.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Login Checkbox Style -->
    <style name="LoginCheckBoxStyle.Agreement" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="android:scaleX">0.8</item>
        <item name="android:scaleY">0.8</item>
        <item name="buttonTint">@color/brand_primary</item>
    </style>
</resources>
