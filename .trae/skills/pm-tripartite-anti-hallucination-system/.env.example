# PM-Tripartite-Anti-Hallucination-System Publishing Configuration
# Copy this file to .env and fill in your credentials

# PyPI API Token (required for publishing)
# Get your token from: https://pypi.org/account/settings/#api-tokens
TWINE_PASSWORD=pypi-your-api-token-here

# GitHub Token (optional, for gh CLI authentication)
# Not needed if you're already logged in with 'gh auth login'
# GITHUB_TOKEN=ghp_your-github-token-here
