# ============================================================
#  北极星AI - 生产环境配置模板 (.env.prod.example)
#  使用方式: 
#    1. 复制此文件为 .env.prod
#    2. 填写真实的密码和密钥（从密钥管理系统获取）
#    3. 运行: ./start.sh prod
#
#  ⚠️  安全警告 (非常重要!)：
#     - 此文件是模板，不包含任何真实密码
#     - 复制后的 .env.prod 文件权限必须设置为 600
#     - 绝对禁止将 .env.prod 提交到 Git 仓库！
#     - 密码必须符合复杂度要求：≥16位，含大小写+数字+特殊字符
#
#  特点:
#    - 生产级安全配置
#    - 日志级别: WARN (减少日志输出)
#    - JVM内存: 较大 (保证性能)
#    - 连接生产数据库/Redis集群
# ============================================================

# ---- 环境标识 ----
ENV=prod

# ====== 🔒 必填项 (必须填写真实值!) ======

# ---- 数据库配置 (MariaDB) ----
DB_HOST=YOUR_PRODUCTION_DB_HOST          # 例如: 10.0.1.100 或 db-prod.internal
DB_PORT=3306
DB_NAME=beijixing_ai
DB_USER=beijixing_prod                    # 建议使用专用应用账号，不要用root
DB_PASSWORD=                              # ⬅️ 必填! 从密钥管理获取
DB_DRIVER=org.mariadb.jdbc.Driver

# ---- Redis配置 ----
REDIS_HOST=YOUR_REDIS_CLUSTER_HOST       # 例如: redis-cluster.internal 或 10.0.1.101
REDIS_PORT=6379
REDIS_PASSWORD=                           # ⬅️ 必填!
REDIS_MAX_IDLE=20                         # 生产环境增加连接池
REDIS_MAX_ACTIVE=200

# ---- JWT认证配置 ----
JWT_SECRET=                               # ⬅️ 必填! ≥64位随机字符串
JWT_EXPIRATION=86400000                   # Token有效期: 24小时

# ====== 📧 可选项 (按需填写) ======

# ---- 邮件服务配置 ----
SMTP_HOST=smtp.your-company.com
SMTP_PORT=465
SMTP_USERNAME=noreply@your-company.com
SMTP_PASSWORD=                             # 从邮件服务商获取

# ---- AI模型配置 ----
AI_PROVIDER_TYPE=volcano                  # volcano / deepseek
VOLCENGINE_API_KEY=                        # 从火山引擎控制台获取
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DEEPSEEK_API_KEY=                          # 从DeepSeek平台获取
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---- 腾讯云短信服务 ----
TENCENT_SECRET_ID=                        # 从腾讯云控制台获取
TENCENT_SECRET_KEY=                       # 从腾讯云控制台获取

# ---- RabbitMQ消息队列 (如果启用) ----
RABBITMQ_HOST=rabbitmq.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=beijixing_prod
RABBITMQ_PASS=                            # 强密码
RABBITMQ_VHOST=/beijixing-prod

# ====== ⚙️ 性能调优参数 ======

# ---- JVM内存配置 (生产环境) ----
JAVA_OPTS=-Xms1024m -Xmx4096m -XX:+UseG1GC -XX:MaxGCPauseMillis=100

# ---- 日志级别 (生产环境降低日志量) ----
LOG_LEVEL=WARN

# ---- 自动确认 (生产环境必须关闭!) ----
AUTO_CONFIRM=false

# ====== 📊 监控与告警 ======

# ---- 监控数据采集频率 (秒) ----
MONITOR_SYSTEM_INTERVAL=30
MONITOR_APP_INTERVAL=15
MONITOR_BUSINESS_INTERVAL=60

# ---- 告警通知 ----
ALERT_WEBHOOK_URL=https://hooks.your-company.com/webhook/ops-alert
ALERT_EMAIL=ops-team@your-company.com,oncall@your-company.com

# ---- 备份配置 ----
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=s3://your-backup-bucket/beijixing-ai

# ====== 🔐 安全加固建议 ======
#
# 文件权限设置:
#   chmod 600 .env.prod
#   chown appuser:appgroup .env.prod
#
# 密码生成命令:
#   openssl rand -base64 48
#
# 密码复杂度检查:
#   - 长度 ≥ 16位
#   - 包含大小写字母 + 数字 + 特殊字符
#   - 不包含字典单词或个人信息
#
# 定期更换:
#   - 数据库密码: 每90天
#   - Redis密码: 每90天
#   - JWT_SECRET: 每180天
#   - API密钥: 按供应商建议
#
# ====== 📋 部署检查清单 ======
#
# [ ] 已从密钥管理系统获取所有密码并填写完整
# [ ] 已验证数据库连接性: mysql -h$DB_HOST -P$DB_PORT -u$DB_USER -p$DB_PASSWORD
# [ ] 已验证Redis连接性: redis-cli -h$REDIS_HOST -p$REDIS_PORT -a$REDIS_PASSWORD ping
# [ ] 已设置文件权限: chmod 600 .env.prod
# [ ] 已测试启动: ./start.sh --check-only
# [ ] 已配置防火墙规则: 仅开放80/443端口（如使用Nginx反向代理）
# [ ] 已配置SSL证书（如需要HTTPS）
# [ ] 已设置自动备份任务
# [ ] 已配置监控告警
# [ ] 已通知运维团队上线时间
#
# ============================================================
