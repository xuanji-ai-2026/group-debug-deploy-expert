# ============================================================
#  北极星AI - 测试环境配置 (.env.test)
#  使用方式: ./start.sh test
#  
#  特点:
#    - 模拟生产环境
#    - 日志级别: INFO
#    - JVM内存: 中等
#    - 连接测试服务器资源
#
#  注意:
#    此文件用于CI/CD和QA测试
#    密码应从测试环境密钥管理系统获取
# ============================================================

# ---- 环境标识 ----
ENV=test

# ---- 数据库配置 (MariaDB) ----
DB_HOST=192.168.1.100
DB_PORT=3306
DB_NAME=beijixing_ai_test
DB_USER=beijixing_test
DB_PASSWORD=Test@Beijixing2024!
DB_DRIVER=org.mariadb.jdbc.Driver

# ---- Redis配置 ----
REDIS_HOST=192.168.1.101
REDIS_PORT=6379
REDIS_PASSWORD=TestRedis@2024!
REDIS_MAX_IDLE=10
REDIS_MAX_ACTIVE=150

# ---- RabbitMQ配置 ----
RABBITMQ_HOST=192.168.1.102
RABBITMQ_PORT=5672
RABBITMQ_USER=beijixing_test
RABBITMQ_PASS=RabbitTest@2024!
RABBITMQ_VHOST=/beijixing-test

# ---- 服务端口配置 ----
APP_PORT=8080

# ---- JVM内存配置 (测试环境) ----
JAVA_OPTS=-Xms512m -Xmx1024m

# ---- 日志级别 ----
LOG_LEVEL=INFO

# ---- 邮件服务配置 ----
SMTP_HOST=smtp.test-company.com
SMTP_PORT=465
SMTP_USERNAME=noreply@test-company.com
SMTP_PASSWORD=TestSmtp@2024!

# ---- JWT认证配置 ----
JWT_SECRET=test_jwt_secret_key_for_qa_testing_environment_2024_secure
JWT_EXPIRATION=86400000

# ---- AI模型配置 ----
AI_PROVIDER_TYPE=volcano
VOLCENGINE_API_KEY=test_volcengine_api_key_here
DEEPSEEK_API_KEY=test_deepseek_api_key_here

# ---- 腾讯云短信 (测试模式，使用沙箱) ----
TENCENT_SECRET_ID=test_tencent_secret_id
TENCENT_SECRET_KEY=test_tencent_secret_key

# ---- 自动确认 (测试环境可以开启) ----
AUTO_CONFIRM=true

# ---- 监控配置 ----
ALERT_WEBHOOK_URL=https://hooks.test.com/webhook/test
ALERT_EMAIL=qa-team@test-company.com
