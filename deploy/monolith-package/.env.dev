# ============================================================
#  北极星AI - 开发环境配置 (.env.dev)
#  使用方式: ./start.sh dev
#  
#  特点:
#    - 本地开发调试友好
#    - 日志级别: DEBUG (详细输出)
#    - JVM内存: 较小 (适合个人电脑)
#    - 数据库/Redis: 使用本地默认值
#
#  安全警告:
#    此文件包含示例密码，仅用于本地开发！
#    生产环境请使用强密码！
# ============================================================

# ---- 环境标识 ----
ENV=dev

# ---- 数据库配置 (MariaDB) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=beijixing_ai
DB_USER=root
DB_PASSWORD=dev_password_123
DB_DRIVER=org.mariadb.jdbc.Driver

# ---- Redis配置 ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_123
REDIS_MAX_IDLE=8
REDIS_MAX_ACTIVE=100

# ---- Nacos配置 (已禁用 - 单体架构) ----
NACOS_ADDR=localhost:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=nacos
NACOS_PASSWORD=nacos

# ---- MongoDB配置 (可选) ----
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=beijixing_logs
MONGO_USER=admin
MONGO_PASS=mongo_dev_123

# ---- RabbitMQ配置 (可选) ----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# ---- Elasticsearch配置 (可选) ----
ES_HOST=localhost
ES_PORT=9200
ES_USER=elastic
ES_PASS=changeme

# ---- 服务端口配置 ----
APP_PORT=8080

# ---- JVM内存配置 (开发环境) ----
JAVA_OPTS=-Xms256m -Xmx768m

# ---- 日志级别 ----
LOG_LEVEL=DEBUG

# ---- 邮件服务配置 (测试用) ----
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USERNAME=test@qq.com
SMTP_PASSWORD=test_smtp_password

# ---- JWT认证配置 (开发用) ----
JWT_SECRET=dev_jwt_secret_key_for_development_only_2024
JWT_EXPIRATION=86400000

# ---- AI模型配置 (使用免费额度) ----
AI_PROVIDER_TYPE=volcano
VOLCENGINE_API_KEY=dev_volcengine_key
DEEPSEEK_API_KEY=dev_deepseek_key

# ---- 腾讯云短信 (测试模式) ----
TENCENT_SECRET_ID=dev_tencent_id
TENCENT_SECRET_KEY=dev_tencent_key

# ---- 自动确认 (开发环境可以开启) ----
AUTO_CONFIRM=true
