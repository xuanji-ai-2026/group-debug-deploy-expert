# 北极星AI商机获客系统 - 环境变量模板
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# 应用版本
# ============================================
APP_VERSION=latest

# ============================================
# MySQL配置
# ============================================
MYSQL_ROOT_PASSWORD=Beijixing@2024!
MYSQL_DATABASE=beijixing_db
MYSQL_USER=beijixing
MYSQL_PASSWORD=Bjx@Db2024#

# ============================================
# Redis配置
