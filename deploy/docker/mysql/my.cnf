# ============================================================
# 北极星AI商机获客系统 - MySQL 配置文件
# Network Engineer: 郑华 (EMP-NETWORK-001)
# Description: MySQL 8.0 生产环境优化配置
# ============================================================

[mysqld]
# ============================================================
# 基础配置
# ============================================================
port = 3306
user = mysql
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid

# 绑定地址（Docker环境中监听所有接口）
bind-address = 0.0.0.0

# 跳过DNS解析，加快连接速度
skip-name-resolve

# 默认认证插件（兼容旧客户端）
default_authentication_plugin = mysql_native_password

# ============================================================
# 字符集和排序规则
# ============================================================
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# 客户端连接字符集
init_connect = 'SET NAMES utf8mb4'

# ============================================================
# 时区配置
# ============================================================
default-time-zone = '+08:00'
log_timestamps = SYSTEM

# ============================================================
# 性能优化 - 内存设置
# ============================================================

# InnoDB缓冲池（建议设置为物理内存的50%-75%）
innodb_buffer_pool_size = 1G

# InnoDB缓冲池实例数（缓冲池>1G时建议设置）
innodb_buffer_pool_instances = 4

# InnoDB日志文件大小
innodb_log_file_size = 256M
innodb_log_files_in_group = 2

# InnoDB日志缓冲区
innodb_log_buffer_size = 16M

# InnoDB刷新日志策略（权衡性能与持久性）
innodb_flush_log_at_trx_commit = 2

# InnoDB刷新方法
innodb_flush_method = O_DIRECT

# 连接缓冲区
join_buffer_size = 256K
sort_buffer_size = 256K
read_buffer_size = 128K
read_rnd_buffer_size = 256K

# 查询缓存（MySQL 8.0已移除，此处保留作为文档）
# query_cache_type = 1
# query_cache_size = 64M

# 临时表大小
tmp_table_size = 64M
max_heap_table_size = 64M

# ============================================================
# 连接和线程配置
# ============================================================

# 最大连接数
max_connections = 500
max_user_connections = 450

# 连接错误限制（防止暴力破解）
max_connect_errors = 100

# 线程缓存
thread_cache_size = 50

# 每个连接允许的最大数据包大小
max_allowed_packet = 64M

# 交互式超时
interactive_timeout = 600
wait_timeout = 600

# ============================================================
# InnoDB事务和锁配置
# ============================================================
innodb_lock_wait_timeout = 50
innodb_rollback_on_timeout = ON

# 事务隔离级别
transaction_isolation = READ-COMMITTED

# ============================================================
# 日志配置
# ============================================================

# 错误日志
log_error = /var/log/mysql/error.log
log_error_verbosity = 3

# 慢查询日志
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 2
log_queries_not_using_indexes = 1
min_examined_row_limit = 100

# 通用查询日志（调试用，生产环境建议关闭）
general_log = 0
general_log_file = /var/log/mysql/general.log

# 二进制日志（用于主从复制和点时间恢复）
server_id = 1
log_bin = /var/log/mysql/mysql-bin
binlog_format = ROW
binlog_row_image = FULL
binlog_expire_logs_seconds = 604800
max_binlog_size = 500M
sync_binlog = 1

# ============================================================
# 表和索引配置
# ============================================================

# 表打开缓存
table_open_cache = 2000
table_definition_cache = 1400

# 文件打开限制
open_files_limit = 65535

# 每个表独立表空间
innodb_file_per_table = 1

# 自动递增模式
innodb_autoinc_lock_mode = 2

# ============================================================
# 安全和审计
# ============================================================

# 本地文件导入（根据需求开启）
local_infile = 0

# 安全文件导入目录
secure_file_priv = /var/lib/mysql-files/

# 审计日志插件（需要安装插件）
# plugin-load = audit_log.so
# audit_log_policy = ALL

# ============================================================
# 监控和性能
# ============================================================

# 性能模式
performance_schema = ON

# InnoDB监控
innodb_status_output = 0
innodb_status_output_locks = 0

# ============================================================
# 死锁检测
# ============================================================
innodb_deadlock_detect = ON
innodb_print_all_deadlocks = 1

[client]
default-character-set = utf8mb8
port = 3306
socket = /var/run/mysqld/mysqld.sock

[mysql]
default-character-set = utf8mb4

[mysqldump]
default-character-set = utf8mb4
quick
quote-names
max_allowed_packet = 64M

[mysqld_safe]
log_error = /var/log/mysql/error.log
nice = 0
open_files_limit = 65535
